DATABASE_URL=postgresql://crawliq:crawliq@localhost:5432/crawliq

# Optional: content-similarity graph (POST /crawl-jobs/{id}/graph/content-similarity-edges).
# GRAPH_SIMILARITY_TOP_K=10
# GRAPH_SIMILARITY_MIN_SCORE=0.15

# Optional: near-duplicate graph (POST /crawl-jobs/{id}/graph/near-duplicate-edges).
# GRAPH_NEAR_DUPLICATE_MIN_SCORE=0.92

# Optional: graph metrics (POST /crawl-jobs/{id}/graph/compute-metrics).
# GRAPH_METRICS_BETWEENNESS_MAX_PAGES=300

# Optional: graph-enhanced search (GET /search?graph_enhanced=true&job_id=...).
# GRAPH_RERANK_SEED_LIMIT=15
# GRAPH_RERANK_MAX_CANDIDATES=200

# Optional: allow POST /search/stats/reset to clear search_queries (p95 / avg latency benchmarks).
# ALLOW_SEARCH_QUERY_LOG_RESET=true
