# Copy to `.env` in the repo root (same folder as `docker-compose.yml`).
# Docker Compose reads `.env` automatically for variable substitution.

DATABASE_URL=postgresql://crawliq:crawliq@postgres:5432/crawliq
# Optional: separate DB for pytest integration tests (same schema after ``alembic upgrade head``).
# CRAWLIQ_TEST_DATABASE_URL=postgresql://crawliq:crawliq@localhost:5432/crawliq_test
REDIS_URL=redis://redis:6379/0

API_PORT=8000
WEB_PORT=3000

# Browser calls API on the host (not the Docker service name).
NEXT_PUBLIC_API_URL=http://localhost:8000

CRAWL_DEFAULT_MAX_PAGES=100
CRAWL_DEFAULT_MAX_DEPTH=2
CRAWL_REQUEST_TIMEOUT_SECONDS=10
CRAWL_DOMAIN_DELAY_SECONDS=1
# Optional: HTTP client User-Agent and body/redirect limits for ``services.fetch_html`` (see ``config.py``). Empty ``CRAWL_HTTP_USER_AGENT`` uses the built-in default.
# CRAWL_HTTP_USER_AGENT=CrawlIQ/0.1 
# CRAWL_MAX_REDIRECTS=10
# CRAWL_MAX_RESPONSE_BYTES=5242880

# --- Docker build only (Compose build args; not used at container runtime) ---
# If `pip install` fails with SSL inside the image, try a PyPI mirror + its trusted host, e.g.:
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_EXTRA_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
# If `npm install` fails with SSL in the web image (last resort; lowers verification):
# NPM_STRICT_SSL=false
# NPM_CONFIG_REGISTRY=https://registry.npmjs.org/
